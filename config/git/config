[user]
	name = dewab
	email = dwhicker@bifrost.cc

[core]
	  editor = vi
	Excludesfile = ~/.config/git/ignore
	  autocrlf = input
	  pager =

[color]
	branch = auto
	diff = auto
	interactive = auto
	status = auto
	ui = auto
	pager = true

[credential]
	helper = cache --timeout=3600

[alias]
	co = checkout
	ci = commit
	cm = commit -am
	st = status
	sb = status -sb
	br = branch
	hist = log --pretty=format:\"%C(magenta)%h%Creset | %C(red)%ad%Creset | %C(green)%an%Creset | %s%d\" --graph --date=short
	lg = !git log --pretty=format:\"%C(magenta)%h%Creset -%C(red)%d%Creset %s %C(dim green)(%cr) [%an]\" --abbrev-commit -30
	type = cat-file -t
	dump = cat-file -p
	aa = add .
	p = push
	pt = push origin --tag
	url = remote get-url --push --all origin

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	features = catppuccin-mocha side-by-side line-numbers decorations
	whitespace-error-style = 22 reverse

[delta "catppuccin-mocha"]
	dark = true
	syntax-theme = Catppuccin Mocha
	minus-style = syntax "#34293a"
	minus-emph-style = syntax "#53394c"
	plus-style = syntax "#2c3439"
	plus-emph-style = syntax "#404f4a"
	line-numbers-minus-style = "#f38ba8"
	line-numbers-plus-style = "#a6e3a1"
	line-numbers-zero-style = "#6c7086"
	line-numbers-left-style = "#45475a"
	line-numbers-right-style = "#45475a"
	hunk-header-style = file line-number syntax
	hunk-header-decoration-style = "#89b4fa" box ul
	hunk-header-line-number-style = "#fab387"

[delta "decorations"]
	commit-decoration-style = bold yellow box ul
	file-style = bold yellow ul
	file-decoration-style = none
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[http]
	postBuffer = 524288000
[push]
	autoSetupRemote = true
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
	#helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
	#helper = !/opt/homebrew/bin/gh auth git-credential
