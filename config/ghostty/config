# Empty values reset the configuration to the default value

# ── Theme ──
theme = Catppuccin Mocha

# ── Font ──
font-family = "FiraCode Nerd Font Mono"
font-family-bold = "FiraCode Nerd Font Mono Bold"
font-size = 15
font-thicken = true
# FiraCode ligatures are ON by default; to kill them: font-feature = -calt,-liga,-dlig
# font-family-italic = "FiraCode Nerd Font Mono"
# font-family-bold-italic = "FiraCode Nerd Font Mono"

# ── macOS keys — required for Alt/Meta bindings in nvim, tmux, fzf ──
macos-option-as-alt = true

# ── Shell integration (zsh; powers cursor shape, prompt jumps, title) ──
# ssh-terminfo installs Ghostty's terminfo on remotes (full keys/colors);
# ssh-env is the fallback (sets TERM=xterm-256color) when it can't, so SSH to
# hosts lacking the xterm-ghostty entry doesn't break arrows/delete/colors.
shell-integration = zsh
shell-integration-features = cursor,sudo,title,ssh-terminfo,ssh-env

# ── Selection / clipboard ──
copy-on-select = clipboard

# ── Window / appearance ──
background-opacity = 0.96
background-blur = 20
macos-titlebar-style = tabs
window-save-state = always
window-padding-x = 8
window-padding-y = 6
mouse-hide-while-typing = true

# ── Quality of life ──
scrollback-limit = 100000
confirm-close-surface = false

# ── Quick dropdown terminal (global hotkey) ──
# Disabled: the global cmd+` hotkey grabbed the key system-wide and conflicted
# with Supacode. Rebind to another key (e.g. global:cmd+escape) to re-enable.
# keybind = global:cmd+grave_accent=toggle_quick_terminal
